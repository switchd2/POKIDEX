generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pokemon {
  id                Int               @id
  nationalDex       Int               @unique
  slug              String            @unique  // "bulbasaur"
  name              String
  nameJapanese      String?
  genus             String?           // "Seed Pokémon"
  generationId      Int
  generation        Generation        @relation(fields: [generationId], references: [id])
  height            Float             // in meters
  weight            Float             // in kg
  catchRate         Int?
  baseFriendship    Int?
  baseExp           Int?
  growthRate        String?
  genderRatio       String?           // "87.5% M / 12.5% F"
  eggCycles         Int?
  hatchTime         Int?
  isLegendary       Boolean           @default(false)
  isMythical        Boolean           @default(false)
  isBaby            Boolean           @default(false)
  hasGenderDiff     Boolean           @default(false)
  colorCategory     String?           // official color category
  shape             String?
  habitat           String?
  description       String?           // main description (lore/origin)
  nameEtymology     String?
  designOrigin      String?
  animeAppearances  String?
  competitiveTier   String?           // OU, UU, NU, etc.
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  types             PokemonType[]
  abilities         PokemonAbility[]
  stats             PokemonStat[]
  moves             PokemonMove[]
  sprites           PokemonSprite[]
  flavorTexts       FlavorText[]
  locations         PokemonLocation[]
  forms             PokemonForm[]
  eggGroups         PokemonEggGroup[]
  evolutionChain    EvolutionChain?   @relation(fields: [evolutionChainId], references: [id])
  evolutionChainId  Int?
  competitiveSets   CompetitiveSet[]
  mediaAppearances  MediaAppearance[]
}

model Type {
  id              Int            @id @default(autoincrement())
  name            String         @unique   // "grass", "fire"
  nameDisplay     String                   // "GRASS", "FIRE"
  pokemon         PokemonType[]
  moves           Move[]
  // effectiveness stored as JSON for simplicity
  strongAgainst   String[]                 // type names it's 2x against
  weakAgainst     String[]                 // type names it's 0.5x against
  immuneTo        String[]                 // type names it's 0x against
}

model PokemonType {
  pokemonId   Int
  typeId      Int
  slot        Int       // 1 = primary, 2 = secondary
  pokemon     Pokemon   @relation(fields: [pokemonId], references: [id])
  type        Type      @relation(fields: [typeId], references: [id])
  @@id([pokemonId, typeId])
}

model Ability {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  nameDisplay String
  description String
  effect      String?          // long effect text
  generation  String?
  pokemon     PokemonAbility[]
}

model PokemonAbility {
  pokemonId   Int
  abilityId   Int
  slot        Int
  isHidden    Boolean   @default(false)
  pokemon     Pokemon   @relation(fields: [pokemonId], references: [id])
  ability     Ability   @relation(fields: [abilityId], references: [id])
  @@id([pokemonId, abilityId])
}

model PokemonStat {
  id          Int     @id @default(autoincrement())
  pokemonId   Int
  statName    String  // hp, attack, defense, sp_atk, sp_def, speed
  baseValue   Int
  effort      Int     // EV yield
  pokemon     Pokemon @relation(fields: [pokemonId], references: [id])
}

model Move {
  id            Int           @id @default(autoincrement())
  name          String        @unique
  nameDisplay   String
  typeId        Int?
  type          Type?         @relation(fields: [typeId], references: [id])
  category      String        // Physical, Special, Status
  power         Int?
  accuracy      Int?
  pp            Int?
  priority      Int?
  effect        String?
  description   String?
  generation    String?
  pokemon       PokemonMove[]
}

model PokemonMove {
  id            Int     @id @default(autoincrement())
  pokemonId     Int
  moveId        Int
  learnMethod   String  // level-up, tm, egg, tutor
  level         Int?    // level learned (if level-up)
  gameVersion   String? // which game version
  pokemon     Pokemon @relation(fields: [pokemonId], references: [id])
  move          Move    @relation(fields: [moveId], references: [id])
}

model PokemonSprite {
  id          Int     @id @default(autoincrement())
  pokemonId   Int
  generation  String? // "gen-1", "gen-2", etc.
  label       String  // "official-artwork", "front-default",
                      // "front-shiny", "back-default", etc.
  url         String  // local path or CDN URL
  isShiny     Boolean @default(false)
  isAnimated  Boolean @default(false)
  pokemon     Pokemon @relation(fields: [pokemonId], references: [id])
}

model FlavorText {
  id          Int     @id @default(autoincrement())
  pokemonId   Int
  gameVersion String  // "Red", "Blue", "Gold", "Scarlet" etc.
  text        String
  language    String  @default("en")
  pokemon     Pokemon @relation(fields: [pokemonId], references: [id])
}

model PokemonLocation {
  id          Int     @id @default(autoincrement())
  pokemonId   Int
  gameVersion String
  location    String
  method      String  // walk, surf, fishing, gift, etc.
  levelMin    Int?
  levelMax    Int?
  rarity      String? // "Common", "Rare", "5%", etc.
  pokemon     Pokemon @relation(fields: [pokemonId], references: [id])
}

model EvolutionChain {
  id        Int       @id @default(autoincrement())
  chainData Json      // store full tree as JSON for flexibility
  pokemon   Pokemon[]
}

model PokemonForm {
  id          Int     @id @default(autoincrement())
  pokemonId   Int
  formName    String  // "Mega Charizard X", "Alolan Vulpix"
  formSlug    String
  isRegional  Boolean @default(false)
  isMega      Boolean @default(false)
  isGmax      Boolean @default(false)
  spriteUrl   String?
  statChanges Json?   // override stats for this form
  typeChanges Json?   // override types for this form
  pokemon     Pokemon @relation(fields: [pokemonId], references: [id])
}

model Generation {
  id            Int       @id @default(autoincrement())
  number        Int       @unique  // 1-9
  name          String    // "Generation I"
  region        String    // "Kanto"
  games         String[]  // ["Red", "Blue", "Yellow"]
  releaseYear   Int
  pokemonCount  Int
  newMechanics  String[]
  description   String?
  pokemon       Pokemon[]
}

model EggGroup {
  id      Int               @id @default(autoincrement())
  name    String            @unique
  pokemon PokemonEggGroup[]
}

model PokemonEggGroup {
  pokemonId   Int
  eggGroupId  Int
  pokemon     Pokemon  @relation(fields: [pokemonId], references: [id])
  eggGroup    EggGroup @relation(fields: [eggGroupId], references: [id])
  @@id([pokemonId, eggGroupId])
}

model CompetitiveSet {
  id          Int     @id @default(autoincrement())
  pokemonId   Int
  setName     String  // "Bulky Pivot", "Sweeper"
  tier        String  // "OU", "UU"
  item        String?
  ability     String?
  nature      String?
  evSpread    String? // "252 HP / 252 Def / 4 SpD"
  moves       String[] // array of 4 move names
  description String?
  pokemon     Pokemon @relation(fields: [pokemonId], references: [id])
}

model MediaAppearance {
  id          Int     @id @default(autoincrement())
  pokemonId   Int
  mediaType   String  // "anime", "manga", "movie", "game"
  title       String
  notes       String?
  pokemon     Pokemon @relation(fields: [pokemonId], references: [id])
}

model SearchIndex {
  id          Int     @id @default(autoincrement())
  entityType  String  // "pokemon", "move", "ability", "item"
  entityId    Int
  slug        String
  displayName String
  keywords    String  // space-separated searchable terms
  @@index([keywords])
}
